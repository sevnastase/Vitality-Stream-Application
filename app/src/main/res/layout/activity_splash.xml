<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="@drawable/splash_screen_background"
    android:theme="@style/ThemeOverlay.FitStream.FullscreenContainer"
    tools:context=".ui.phone.splash.SplashActivity">

    <TextView
        android:id="@+id/network_download_speed_textview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="14sp"
        android:layout_margin="10dp"
        app:layout_constraintRight_toLeftOf="@id/network_latency_textview"/>

    <TextView
        android:id="@+id/network_latency_textview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:layout_margin="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/loading_stage_description_textview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:text=""
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="60dp"
        android:visibility="visible" />

    <SeekBar
        android:id="@+id/loading_progress_bar"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:progressDrawable="@drawable/praxfilm_progress_drawable"
        android:thumb="@drawable/bicycle_thumb_praxfilm"
        android:thumbOffset="0dp"
        android:splitTrack="false"
        android:enabled="false"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>